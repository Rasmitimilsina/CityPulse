{
  "type": "object",
  "properties": {
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "engine": {
            "type": "string",
            "enum": [
              "google",
              "bing",
              "yandex"
            ],
            "default": "google"
          },
          "cursor": {
            "type": "string"
          },
          "geo_location": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "2-letter country code for geo-targeted results (e.g., \"us\", \"uk\")"
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false
      },
      "minItems": 1,
      "maxItems": 5
    }
  },
  "required": [
    "queries"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}