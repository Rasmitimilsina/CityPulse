{
  "type": "object",
  "properties": {
    "query": {
      "type": "string"
    },
    "engine": {
      "type": "string",
      "enum": [
        "google",
        "bing",
        "yandex"
      ],
      "default": "google"
    },
    "cursor": {
      "type": "string",
      "description": "Pagination cursor for next page"
    },
    "geo_location": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2,
      "description": "2-letter country code for geo-targeted results (e.g., \"us\", \"uk\")"
    }
  },
  "required": [
    "query"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}